# Cloned repos (managed by setup.sh)
youcoded/
youcoded-core/
youcoded-admin/
wecoded-themes/
wecoded-marketplace/

# Worktrees and temp directories
.worktrees/
*-worktree*/
*-unified/
*-phase*/
*-decoupling/
*-sessions/

# Skill runtime state (brainstorming/writing-plans session dirs etc).
# Contain ephemeral working notes from skill invocations and don't carry
# value across machines.
.superpowers/

# Ad-hoc scratch dir occasionally used for files we don't want to track.
# If something proves useful, promote it to scripts/ or docs/.
scratch/

# Auto-title artifacts
.auto-title
.auto-title-audit.tmp

# Claude project config
# Track: commands/, hooks/, rules/, skills/, settings.json (shared across machines)
# Ignore: settings.local.json (user/machine-specific), worktrees/
.claude/*
!.claude/commands/
!.claude/hooks/
!.claude/rules/
!.claude/skills/
!.claude/settings.json
.youcoded/

# Worktree container dirs (per-repo .wt convention)
*.wt/
