# Cloned repos (managed by setup.sh)
youcoded/
youcoded-core/
youcoded-admin/
wecoded-themes/
wecoded-marketplace/

# Worktrees and temp directories
*-worktree*/
*-unified/
*-phase*/
*-decoupling/
*-sessions/

# Auto-title artifacts
.auto-title
.auto-title-audit.tmp

# Claude project config
# Track: commands/, hooks/, rules/, skills/, settings.json (shared across machines)
# Ignore: settings.local.json (user/machine-specific), worktrees/
.claude/*
!.claude/commands/
!.claude/hooks/
!.claude/rules/
!.claude/skills/
!.claude/settings.json
